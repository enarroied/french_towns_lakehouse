# Infrastructure
MINIO_ENDPOINT=http://localhost:19000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# AWS (used by DuckDB/dbt)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=localhost:19000
AWS_DEFAULT_REGION=us-east-1

# Polaris (Iceberg catalog)
POLARIS_CLIENT_ID=
POLARIS_CLIENT_SECRET=

# Project
FRENCH_TOWNS_ROOT=/path/to/french_towns_lakehouse

# PostgreSQL (metadata database)
PG_PASSWORD=
AUDIT_DATABASE_URL=postgresql://french_towns:${PG_PASSWORD}@localhost:5432/metadata
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://french_towns:${PG_PASSWORD}@localhost:5432/prefect
